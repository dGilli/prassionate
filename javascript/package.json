{
  "name": "prassionate-tracker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^23.0.0",
    "terser": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "dist/tracker.umd.cjs",
  "module": "dist/tracker.js",
  "types": "dist/tracker.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tracker.js",
      "require": "./dist/tracker.umd.cjs",
      "types": "./dist/tracker.d.ts"
    }
